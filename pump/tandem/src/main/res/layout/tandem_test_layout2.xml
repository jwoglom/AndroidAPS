<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/tcc_header"
        android:paddingTop="15dp"
        android:paddingBottom="2dp"
        android:textStyle="bold"
        android:paddingLeft="20dp"
        android:text="Main Title"

        android:textSize="16pt"
        android:background="@color/aaps_theme_light_inverseOnSurface"
        >

    </TextView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/tcc_header"
        android:layout_marginTop="4dp"
        android:id="@+id/tcc_main_container"


        android:background="@color/aaps_theme_dark_onPrimaryContainer">






        <Button
            android:id="@+id/tcc_leftButton"
            android:layout_width="150dp"
            android:layout_height="40dp"
            android:background="@color/aaps_theme_dark_onBackground"
            android:layout_marginStart="40dp"
            android:text="Cancel"
            android:layout_alignParentBottom="true"
            />

        <Button
            android:id="@+id/tcc_rightButton"
            android:layout_width="150dp"
            android:layout_height="40dp"
            android:text="Next"
            android:background="@color/aaps_theme_dark_onBackground"

            android:layout_marginLeft="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="50dp"
            android:layout_toEndOf="@+id/tcc_leftButton"
            android:layout_alignParentBottom="true"

            />


        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="50px"
                android:background="@color/devSlopePos"

                >

                <TextView
                    android:id="@+id/tcc_title"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="80px"
                    android:text="Text2"
                    android:textAlignment="center"
                    android:textSize="22sp"
                    android:textStyle="bold"


                    />



            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="89dp">


                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/tcc_image"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    app:srcCompat="@drawable/img"
                    />


            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="100dp"
                >
                <Button
                    android:text="Test"></Button>

            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="10dp" >

                <Button
                    android:text="Test"
                    ></Button>

            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="10dp" >

                <Button
                    android:text="Test"
                    ></Button>

            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="10dp" >

                <Button
                    android:text="Test"
                    ></Button>

            </TableRow>


        </TableLayout>


    </RelativeLayout>

</RelativeLayout>