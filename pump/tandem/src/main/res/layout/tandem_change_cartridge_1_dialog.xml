<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aaps_theme_dark_onPrimaryContainer"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/tnd_action_header"
        style="@style/StyleDialogHeader"
        android:layout_width="match_parent"
        android:background="@color/aaps_theme_light_onPrimary"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <TextView
            android:id="@+id/tnd_action_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"


            android:layout_marginTop="20sp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:text="Title"
            android:textAlignment="center"
            android:textAppearance="?android:attr/textAppearanceLarge" />
    </RelativeLayout>


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tnd_step_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="18sp"
        android:padding="8dp"
        android:text="Title"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/equil_header" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/tnd_imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_skip"
        app:layout_constraintDimensionRatio="260:195"
        app:layout_constraintTop_toBottomOf="@+id/tv_hint"
        app:layout_constraintWidth_percent="0.7"
        app:srcCompat="@drawable/img"

        />



    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tnd_details"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18sp"
        android:gravity="center"
        android:padding="8dp"
        android:text="Details"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/equil_header" />




    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tnd_status"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="18sp"
        android:padding="8dp"
        android:text="Status"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/equil_header" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50sp"
        android:gravity="center"
        android:layout_gravity="end">

        <Button
            android:id="@+id/btn_cancel"

            android:layout_width="120dp"

            android:layout_height="match_parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_need"
            android:text="Left" />

        <Button
            android:id="@+id/btn_ok"
            android:layout_width="120dp"

            android:layout_height="match_parent"
            android:text="Right"
            android:layout_marginLeft="150px"
            app:layout_constraintBottom_toBottomOf="@+id/btn_skip"
            app:layout_constraintEnd_toStartOf="@+id/btn_skip" />
    </LinearLayout>


</LinearLayout>
